{
  "expo": {
    "name": "Athlr",
    "slug": "athlr",
    "version": "0.1.0",
    "icon": "./assets/images/icon.png",
    "orientation": "portrait",
    "scheme": "athlr",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.brilwors.athlr",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Athlr uses your location to track your runs, rides and walks.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Athlr tracks your activity in the background so your route keeps recording when the screen is off.",
        "UIBackgroundModes": ["location"],
        "NSHealthShareUsageDescription": "Athlr reads your workouts, heart rate, and routes from Apple Health so you can see all your activity in one place — including data from Apple Watch, Garmin, and other apps.",
        "NSHealthUpdateUsageDescription": "Athlr can write completed activities to Apple Health so your workouts appear in your health record.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.455854898290-al6qt69ku3o3p786f6dvhp5aq59skcb9"
            ]
          }
        ]
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true
      }
    },
    "android": {
      "package": "com.brilwors.athlr",
      "versionCode": 1,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_TOTAL_CALORIES_BURNED",
        "android.permission.health.READ_ELEVATION_GAINED",
        "android.permission.health.READ_SPEED",
        "android.permission.health.WRITE_EXERCISE",
        "android.permission.health.WRITE_HEART_RATE",
        "android.permission.health.WRITE_DISTANCE",
        "android.permission.health.WRITE_STEPS"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Athlr tracks your activity in the background so your route keeps recording when the screen is off.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-sqlite",
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
