rules_version = '2';

// Athlr Firestore security rules.
// Deploy: Firebase Console → Firestore Database → Rules → paste → Publish
// (or `firebase deploy --only firestore:rules` with the Firebase CLI)
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.email == 'admin@brilworks.com'
        || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // ── Admin allowlist ──────────────────────────────────────────────────
    // Add a doc with the admin's auth UID as the document ID (content can
    // be e.g. { role: 'admin' }). Only editable from the Firebase console
    // or by existing admins.
    match /admins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    // ── Users ────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();

      match /following/{targetUid} {
        allow read: if signedIn();
        allow write: if signedIn() && (request.auth.uid == uid || isAdmin());
      }
      match /followers/{followerUid} {
        allow read: if signedIn();
        // The follower writes into the target's followers subcollection
        allow write: if signedIn() && (request.auth.uid == followerUid || isAdmin());
      }
    }

    // ── Shared activities (community feed) ──────────────────────────────
    match /activities/{activityId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && (request.resource.data.uid == request.auth.uid || isAdmin());
      // Owners/admins can update anything; anyone signed in may update
      // ONLY the denormalized kudosCount (kudo toggles on others' posts).
      allow update: if signedIn()
        && (
          request.resource.data.uid == request.auth.uid
          || isAdmin()
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['kudosCount'])
        );
      allow delete: if signedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());

      match /kudos/{userId} {
        allow read: if signedIn();
        allow write: if signedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    // ── Challenges / clubs ───────────────────────────────────────────────
    match /challenges/{challengeId} {
      allow read: if signedIn();
      // Participant-count bumps from the app are merge-writes by signed-in
      // users; full management is admin-only.
      allow create, update: if signedIn();
      allow delete: if isAdmin();

      match /participants/{uid} {
        allow read: if signedIn();
        allow write: if signedIn() && (request.auth.uid == uid || isAdmin());
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
